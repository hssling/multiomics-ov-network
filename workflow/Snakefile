rule download_gdc:
    output:
        "data/raw/gdc/gdc_download_manifest.tsv",
        "data/raw/gdc/download_complete.flag"
    log:
        "results/tables/log_download_gdc.txt"
    shell:
        "python scripts/01_download/01_gdc_download.py --config configs/cohort.yaml > {log} 2>&1"

rule fetch_gdc_files:
    input:
        "data/raw/gdc/download_complete.flag"
    output:
        "data/raw/gdc/files_fetch_complete.flag"
    log:
        "results/tables/log_fetch_gdc_files.txt"
    shell:
        "python scripts/01_download/03_fetch_gdc_files.py --config configs/cohort.yaml > {log} 2>&1 && echo ok > {output}"

